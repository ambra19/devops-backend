{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Commonjs",
        "moduleResolution": "Node",
        "baseUrl": "./src",
        "paths": {
            "@services/*": ["services/*"]
        },
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "**/*.spec.ts"] // needed??
}